#!/bin/bash
# 目标：安全的根分区扩容脚本，适用于 Debian，带安全校验和硬件寿命优化

set -e # 遇到错误即退出

# 1. 检测根分区和所属磁盘
ROOT_DEV=$(findmnt -n -o SOURCE / | sed 's~\[.*\]~~')
DISK_DEV=$(lsblk -n -d -o PKNAME "$ROOT_DEV")
[ -z "$DISK_DEV" ] && DISK_DEV=$(echo "$ROOT_DEV" | sed 's/[0-9]*//g')
DISK_DEV="/dev/$DISK_DEV"
PART_NUM=$(echo "$ROOT_DEV" | sed 's/.*[^0-9]//')

echo "▶ 发现根分区: $ROOT_DEV"
echo "▶ 发现磁盘设备: $DISK_DEV"
echo "▶ 发现分区号: $PART_NUM"

# 2. 安全校验：确认分区表类型
PART_TABLE_TYPE=$(parted -s "$DISK_DEV" print | grep "Partition Table" | awk '{print $3}')
echo "▶ 分区表类型: $PART_TABLE_TYPE"

# 3. 硬件寿命优化逻辑 (针对 SD 卡/EMMC)
# 检测磁盘容量。如果是小容量媒体，留出更多备用空间
DISK_SIZE_GB=$(lsblk -n -d -b -o SIZE "$DISK_DEV" | awk '{print $1/1024/1024/1024}')
echo "▶ 磁盘大小: ${DISK_SIZE_GB} GB"

# 设置扩容边界 (100% 减去一定的备用空间)
if (( $(echo "$DISK_SIZE_GB < 4" | bc -l) )); then
    # 4GB 以下媒体，留出 5% 备用空间
    TARGET_SIZE="95%"
    echo "▶ 4GB 以下媒体 - 留出 5% 备用空间延长寿命"
elif (( $(echo "$DISK_SIZE_GB < 8" | bc -l) )); then
    # 8GB 以下媒体，留出 2% 备用空间
    TARGET_SIZE="98%"
    echo "▶ 8GB 以下媒体 - 留出 2% 备用空间延长寿命"
else
    # 较大媒体，留出 1% 备用空间
    TARGET_SIZE="99%"
    echo "▶ 较大媒体 - 留出 1% 备用空间延长寿命"
fi

# 4. 安全执行扩容
echo "▶ 正在将分区 $PART_NUM 扩容至 $TARGET_SIZE..."
parted -s "$DISK_DEV" resizepart "$PART_NUM" "$TARGET_SIZE"

# 5. 通知内核更新分区表
echo "▶ 通知内核更新分区表..."
partprobe "$DISK_DEV"
sleep 2 # 给内核一点时间处理

# 6. 扩容文件系统
echo "▶ 正在扩容文件系统..."
# 检测文件系统类型并执行对应命令
FSTYPE=$(lsblk -n -o FSTYPE "$ROOT_DEV")
case "$FSTYPE" in
    ext4)
        resize2fs "$ROOT_DEV"
        ;;
    xfs)
        xfs_growfs /
        ;;
    btrfs)
        btrfs filesystem resize max /
        ;;
    *)
        echo "⚠️ 不支持的文件系统类型: $FSTYPE"
        exit 1
        ;;
esac

echo "✅ 扩容完成！"
